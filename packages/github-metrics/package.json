{
  "name": "@sit-onyx/github-metrics",
  "version": "0.1.0",
  "description": "Utilities for collecting metrics for GitHub projects",
  "bugs": {
    "url": "https://github.com/SchwarzIT/onyx/issues"
  },
  "license": "Apache-2.0",
  "author": "Schwarz Digits IT KG",
  "repository": {
    "type": "git",
    "url": "https://github.com/SchwarzIT/onyx",
    "directory": "packages/github-metrics"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "pnpm run '/^dev:/'",
    "dev:build": "pnpm run build --watch",
    "dev:run": "node --env-file-if-exists=.env --watch --experimental-strip-types ./scripts/onyx.ts",
    "build": "rm -rf ./dist && tsc",
    "test": "vitest"
  },
  "devDependencies": {
    "@sit-onyx/shared": "workspace:^"
  },
  "engines": {
    "node": ">=20"
  }
}
