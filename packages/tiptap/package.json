{
  "name": "@sit-onyx/tiptap",
  "version": "0.3.0",
  "description": "A rich text editor powered by the Tiptap editor and the onyx design system created by Schwarz Digits",
  "bugs": {
    "url": "https://github.com/SchwarzIT/onyx/issues"
  },
  "license": "Apache-2.0",
  "author": "Schwarz Digits IT KG",
  "repository": {
    "type": "git",
    "url": "https://github.com/SchwarzIT/onyx",
    "directory": "packages/tiptap"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    },
