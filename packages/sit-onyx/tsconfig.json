{
  "extends": ["@vue/tsconfig/tsconfig.dom.json", "@vue/tsconfig/tsconfig.lib.json"],
  "include": ["../components/src/index.ts", "../components/src/env.d.ts"],
  "compilerOptions": {
    "incremental": true,
    "verbatimModuleSyntax": null,
    "declaration": true,
    "declarationDir": "./dist",
    "emitDeclarationOnly": true,
    "tsBuildInfoFile": "./dist/tsconfig.app.tsbuildinfo",
    "rootDir": "../components/src/",
    "outDir": "./dist",
    "baseUrl": "../components/src/"
  }
}
