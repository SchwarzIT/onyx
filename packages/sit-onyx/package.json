{
  "name": "sit-onyx",
  "version": "1.15.0",
  "description": "A design system and Vue.js component library created by Schwarz Digits",
  "homepage": "https://onyx.schwarz",
  "bugs": {
    "url": "https://github.com/SchwarzIT/onyx/issues"
  },
  "license": "Apache-2.0",
  "author": "Schwarz Digits IT KG",
  "repository": {
    "type": "git",
    "url": "https://github.com/SchwarzIT/onyx",
    "directory": "packages/sit-onyx"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "type": "module",
  "module": "./dist/index.esm-bundler.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/index.js",
      "default": "./dist/index.esm-bundler.js"
    },
    "./style.css": "./dist/style.css",
    "./global.css": "./src/styles/global.css",
    "./locales/*": "./dist/i18n/locales/*",
    "./src/styles/*": "./src/styles/*",
    "./breakpoints.scss": "./src/styles/breakpoints.scss",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build": "tsx ./build/index.ts && tsc -p tsconfig.locales.json --composite false",
    "build:storybook": "storybook build",
    "preview": "vite serve storybook-static",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:playwright": "playwright install && playwright test",
    "stylelint": "stylelint \"dist/**/*.css\""
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/experimental-ct-vue": "catalog:",
    "@playwright/test": "catalog:",
    "@sit-onyx/flags": "workspace:^",
    "@sit-onyx/headless": "workspace:^",
    "@sit-onyx/playwright-utils": "workspace:^",
    "@sit-onyx/shared": "workspace:^",
    "@sit-onyx/storybook-utils": "workspace:^",
    "@sit-onyx/vite-plugin-component-meta": "workspace:^",
    "@storybook/addon-a11y": "^10.4.6",
    "@vue/compiler-dom": "catalog:",
    "@vue/test-utils": "^2.4.11",
    "axe-core": "^4.12.1",
    "postcss-scss": "^4.0.9",
    "sass-embedded": "catalog:",
    "storybook-addon-tag-badges": "^3.1.0",
    "tsx": "^4.22.4",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vue": "catalog:",
    "vue-component-type-helpers": "^3.3.5",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "peerDependencies": {
    "@sit-onyx/icons": "workspace:^",
    "typescript": ">= 5.2.2",
    "vue": ">= 3.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
